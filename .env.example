# Echo uses Gemini for mirroring, tagging, and summaries.

# Your Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=

# How many entries before a theme summary is generated (default: 15)
SUMMARY_EVERY=15

# Backend port (default: 5050)
PORT=5050

# Frontend: set to your deployed backend URL (leave empty for web-only mode)
VITE_API_BASE=http://localhost:5050
